# CoinGlass Liquidation Heatmap Agent
# Skopiuj do .env i uzupełnij wartości. Hasła i tokeny trzymaj tylko w .env (nie commituj).

# URL strony do zrzutu ekranu (domyślnie: dashboard Hyperliquid na CoinGlass)
# HEATMAP_URL=https://www.coinglass.com/hyperliquid

# Klasyczna mapa likwidacji (BTC) – używana do pobrania „czystej” heatmapy
# przyciskiem aparatu.
# LIQUIDATION_HEATMAP_URL=https://www.coinglass.com/pro/futures/LiquidationHeatMap?coin=BTC&type=symbol

# Katalog na screenshoty (domyślnie: screenshots)
# SCREENSHOT_DIR=screenshots

# Czas oczekiwania po załadowaniu strony (ms) – wykresy mogą ładować się dynamicznie
# WAIT_AFTER_LOAD_MS=5000

# Przeglądarka w tle (true) czy z oknem (false, do debugu)
# HEADLESS=true

# --- CoinGlass logowanie (opcjonalne, do scrapingu UI) ---
# Włącz scraping po zalogowaniu (logowanie przez Playwright).
# COINGLASS_SCRAPE_ENABLED=true
# Dane logowania do CoinGlass (używaj tylko na swoim koncie, zgodnie z regulaminem).
# COINGLASS_EMAIL=twoj_email@domena.com
# COINGLASS_PASSWORD=twoje_haslo

# --- Bybit (publiczne API, do raportu) ---
# Symbol kontraktu, np. BTCUSDT, ETHUSDT (perpetual USDT).
# BYBIT_SYMBOL=BTCUSDT
# Kategoria API: spot / linear / inverse / option. Dla perpetual USDT użyj "linear".
# BYBIT_CATEGORY=linear

# --- Zaawansowana analiza (Claude) ---
# Ustaw na true, aby wysyłać screenshoty + liczby do Claude'a
# i otrzymać rozbudowaną analizę tradingową w mailu / Telegramie.
# RUN_ADVANCED_ANALYSIS=false
# CLAUDE_API_KEY=twój_klucz_api_claude

# --- E-mail (SMTP) ---
SEND_EMAIL=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=twoj@email.com
# EMAIL_SUBJECT_PREFIX=CoinGlass Liquidation Heatmap

# --- Telegram ---
SEND_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
